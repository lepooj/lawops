# === LawOps — Environment Variables ===

# Database (PostgreSQL)
# Docker Compose default: lawops/lawops_dev on port 5432
DATABASE_URL="postgresql://lawops:lawops_dev@localhost:5432/lawops?schema=public"

# Auth (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# AI Provider (OpenAI)
# Required for analysis generation. Without this, the app runs but cannot generate analyses.
OPENAI_API_KEY=""

# Optional: override the default model
# OPENAI_MODEL="gpt-4o"

# App URL (used for redirects, CSRF)
# Default: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
